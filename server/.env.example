NODE_ENV=development
PORT=5001

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=gao0.2

# Required in all environments (no fallback secrets)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins.
# Use "*" only for local development.
CORS_ORIGIN=*

# Enable when behind a reverse proxy/load balancer (nginx, render, etc.)
TRUST_PROXY=false

# Request limits / hardening
BODY_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Super admin phone (used for role elevation)
SUPER_ADMIN_PHONE=1234567890